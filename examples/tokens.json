{
  "$schema": "tokens/1.0",

  "spacing": {
    "xs": "0.25rem",
    "sm": "0.5rem",
    "md": "1rem",
    "lg": "1.5rem",
    "xl": "2rem",
    "2xl": "3rem"
  },

  "radius": {
    "none": "0",
    "sm": "0.25rem",
    "md": "0.5rem",
    "lg": "1rem",
    "full": "9999px"
  },

  "typography": {
    "font": {
      "default": "system-ui, -apple-system, sans-serif",
      "mono": "ui-monospace, monospace"
    },
    "size": {
      "xs": "0.75rem",
      "sm": "0.875rem",
      "md": "1rem",
      "lg": "1.125rem",
      "xl": "1.25rem",
      "2xl": "1.5rem"
    },
    "weight": {
      "normal": "400",
      "medium": "500",
      "semibold": "600",
      "bold": "700"
    },
    "lineHeight": {
      "tight": "1.25",
      "normal": "1.5",
      "relaxed": "1.75"
    }
  },

  "color": {
    "button": {
      "default": {
        "background": {
          "default": "#3b82f6",
          "hover": "#2563eb",
          "active": "#1d4ed8"
        },
        "color": {
          "default": "#ffffff"
        }
      },
      "primary": {
        "background": {
          "default": "#2563eb",
          "hover": "#1d4ed8",
          "active": "#1e40af"
        },
        "color": {
          "default": "#ffffff"
        }
      },
      "secondary": {
        "background": {
          "default": "#6b7280",
          "hover": "#4b5563",
          "active": "#374151"
        },
        "color": {
          "default": "#ffffff"
        }
      },
      "ghost": {
        "background": {
          "default": "transparent",
          "hover": "#f3f4f6",
          "active": "#e5e7eb"
        },
        "color": {
          "default": "#374151",
          "hover": "#111827"
        }
      },
      "danger": {
        "background": {
          "default": "#ef4444",
          "hover": "#dc2626",
          "active": "#b91c1c"
        },
        "color": {
          "default": "#ffffff"
        }
      }
    },

    "text": {
      "primary": "#111827",
      "secondary": "#4b5563",
      "muted": "#9ca3af"
    },

    "surface": {
      "default": "#ffffff",
      "muted": "#f9fafb",
      "accent": "#f3f4f6"
    },

    "border": {
      "default": "#e5e7eb",
      "muted": "#f3f4f6"
    },

    "input": {
      "background": {
        "default": "#ffffff",
        "disabled": "#f9fafb"
      },
      "border": {
        "default": "#e5e7eb",
        "hover": "#d1d5db",
        "focus": "#3b82f6",
        "error": "#ef4444",
        "disabled": "#e5e7eb"
      },
      "text": {
        "default": "#111827",
        "placeholder": "#9ca3af",
        "disabled": "#9ca3af"
      }
    }
  }
}
